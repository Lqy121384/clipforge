# Runtime
CLIPFORGE_ENVIRONMENT=development
CLIPFORGE_HOST=0.0.0.0
CLIPFORGE_PORT=8000
CLIPFORGE_LOG_LEVEL=INFO

# Security (JSON list; leave empty only for local development)
CLIPFORGE_API_KEYS=["replace-with-a-long-random-key"]
CLIPFORGE_CORS_ORIGINS=["http://localhost:8000"]
CLIPFORGE_RATE_LIMIT_PER_MINUTE=120

# Model: mock starts instantly; openclip enables real inference
CLIPFORGE_MODEL_BACKEND=mock
CLIPFORGE_MODEL_NAME=ViT-B-32
CLIPFORGE_MODEL_PRETRAINED=laion2b_s34b_b79k
CLIPFORGE_MODEL_ID=google/siglip2-base-patch16-224
CLIPFORGE_MODEL_DEVICE=auto
CLIPFORGE_MODEL_PRECISION=auto
CLIPFORGE_MODEL_ATTENTION=sdpa
CLIPFORGE_MODEL_COMPILE=false
CLIPFORGE_MODEL_WARMUP=true
CLIPFORGE_EMBEDDING_DIMENSION=512
CLIPFORGE_MAX_BATCH_SIZE=64
CLIPFORGE_MAX_IMAGE_BYTES=10485760

# Local index
CLIPFORGE_INDEX_CAPACITY=100000
CLIPFORGE_VECTOR_STORE_PATH=data/clipforge.db
CLIPFORGE_DEFAULT_TENANT_ID=default
CLIPFORGE_DEFAULT_COLLECTION=main
CLIPFORGE_MAX_CONCURRENT_INFERENCE=1
CLIPFORGE_INFERENCE_CACHE_SIZE=4096
CLIPFORGE_JOB_WORKERS=1
CLIPFORGE_JOB_HISTORY_LIMIT=1000
